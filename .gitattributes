# Normalize line endings: store text as LF in the repo, check out native.
* text=auto eol=lf

# Explicit text types
*.js    text eol=lf
*.mjs   text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.geojson text eol=lf

# Binary assets — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.wasm binary
